{
	"$schema": "https://raw.githubusercontent.com/khulnasoft/codeinfra/master/pkg/codegen/schema/codeinfra.json",
	"name": "other",
	"version": "0.1.0",
	"resources": {
		"other:index:Thing": {
			"inputProperties": {
				"idea": {
					"type": "string"
				}
			}
		},
		"other:module:Object": {
			"inputProperties": {
				"answer": {
					"type": "number"
				}
			}
		},
		"other:module/sub:Object": {
			"inputProperties": {
				"answer": {
					"type": "number"
				}
			}
		}
	},
	"language": {
		"nodejs": {
			"packageName": "@third-party/codeinfra-other"
		},
		"csharp": {
			"rootNamespace": "ThirdParty"
		},
		"python": {
			"packageName": "third_party"
		},
		"go": {
			"importBasePath": "git.example.org/thirdparty/sdk/go/pkg",
			"modulePath": "git.example.org/thirdparty/sdk"
		}
	},
	"provider": {
		"inputProperties": {
			"name": {
				"type": "string"
			},
			"objectProp": {
				"type": "object",
				"propertyNames": {
					"prop1": {
						"type": "string"
					},
					"prop2": {
						"type": "string"
					},
					"prop3": {
						"type": "string"
					}
				}
			}
		}
	}
}
